# Anthropic API key — required for real AI reviews
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the SQLite database file path (default: operational_review.db)
DB_PATH=operational_review.db

# Optional: backend port (default: 5000)
PORT=5000

# Optional: override the backend URL in the frontend (default: http://localhost:5000)
VITE_API_URL=http://localhost:5000
