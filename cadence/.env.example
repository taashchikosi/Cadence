# ── DeepSeek ───────────────────────────────────────────────────────────────
# Get from: platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-...

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: Supabase project → Settings → API
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ── ElevenLabs (optional — mock TTS used if absent) ─────────────────────────
ELEVENLABS_API_KEY=sk_...
# Override default voice IDs if you want different voices
# ELEVENLABS_FEMALE_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MALE_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5001
